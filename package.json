{
  "name": "schibbs-mic",
  "version": "0.2.0",
  "private": true,
  "description": "a browser and windows desktop voice, camera, chat, room, and screen sharing app.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node server.js",
    "desktop:dev": "electron electron/main.cjs",
    "desktop:build:win": "electron-builder --win",
    "check": "node --check server.js && node --check electron/main.cjs && node --check public/app.js && node --check public/service-worker.js"
  },
  "keywords": [
    "chat",
    "voice",
    "camera",
    "webrtc",
    "screen-sharing",
    "pwa",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.schibbsmic.desktop",
    "productName": "schibb's mic",
    "files": [
      "server.js",
      "public/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "schibbs-mic-setup-${version}.${ext}"
    },
    "directories": {
      "buildResources": "public"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ysibal",
        "repo": "schibbs_mic",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "schibb's mic"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
